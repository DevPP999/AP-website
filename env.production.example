# Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NODE_ENV=production

# Google Services
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_SHEET_ID=your_google_sheet_id

# Discord Integration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Google Apps Script URLs
# Contact Form Handler
GOOGLE_APPS_SCRIPT_CONTACT_URL=https://script.google.com/macros/s/YOUR_CONTACT_SCRIPT_ID/exec
# Job Application Handler  
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_APPLICATION_SCRIPT_ID/exec

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Custom Analytics Endpoint
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics.com/api
